{
  "name": "jobblitz-ai",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "tools/*",
    "mcp/*"
  ],
  "scripts": {
    "dev:all": "bash scripts/dev-all.sh",
    "dev:ts": "turbo run dev --filter=!apps/api-legacy",
    "dev:python": "cd apps/api-legacy && uvicorn app.main:app --reload --port 8000",
    "test:all": "turbo run test && cd apps/api-legacy && pytest -x -q",
    "build:all": "turbo run build",
    "deploy": "bash scripts/deploy-fly.sh",
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "biome format --write .",
    "db:migrate": "bun run --filter=db migrate",
    "db:seed": "bun run --filter=db seed",
    "db:studio": "bun run --filter=db studio",
    "db:generate": "bun run --filter=db generate",
    "evals": "bun run --filter=evals run",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "turbo": "^2.4.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  },
  "packageManager": "bun@1.2.0",
  "engines": {
    "bun": ">=1.2.0"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.218.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-metrics": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "langfuse": "^3.38.20"
  }
}
