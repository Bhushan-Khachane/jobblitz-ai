# ──────────────────────────────────────────────────────────────────────────────
# JobBlitz AI — Environment Variables
# Copy this file to .env and fill in the values.
# ──────────────────────────────────────────────────────────────────────────────

# ═══════════════════════════════════════════════════════════════════════════════
# REQUIRED — App will not start without these
# ═══════════════════════════════════════════════════════════════════════════════

# PostgreSQL connection string (Supabase pooler URL in prod)
DATABASE_URL=postgresql+asyncpg://jobblitz:jobblitz@postgres:5432/jobblitz

# JWT signing secret — minimum 32 characters, use: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# Fernet key for encrypting stored credentials — generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# SUPABASE (Production)
# ═══════════════════════════════════════════════════════════════════════════════

# Supabase project URL (for Auth, Storage, Realtime)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_BUCKET_NAME=screenshots

# ═══════════════════════════════════════════════════════════════════════════════
# REDIS (Upstash in prod, local Redis in dev)
# ═══════════════════════════════════════════════════════════════════════════════

REDIS_URL=redis://redis:6379/0

# ═══════════════════════════════════════════════════════════════════════════════
# LLM Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# Primary: Google Gemini (legacy key name, kept for backwards compatibility)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Google AI Studio (new 3-plane architecture)
GOOGLE_AI_STUDIO_API_KEY=
GOOGLE_AI_STUDIO_API_KEY_2=
GOOGLE_AI_STUDIO_API_KEY_3=
GEMINI_FALLBACK_MODEL=gemini-2.0-flash

# ── Ollama Pro (preferred provider) ────────────────────────
OLLAMA_BASE_URL=https://api.ollama.ai
OLLAMA_API_KEY=your_ollama_pro_key_here
OLLAMA_PRO_MODEL=kimi-k2
OLLAMA_FAST_MODEL=llama3.3:70b

# Fallback: OpenAI (used when Gemini is unavailable)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LLM_FALLBACK_ENABLED=true

# ═══════════════════════════════════════════════════════════════════════════════
# Job Discovery APIs (free tiers available)
# ═══════════════════════════════════════════════════════════════════════════════

# Adzuna: sign up at https://developer.adzuna.com (free 10k calls/mo)
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key
# Jooble: sign up at https://jooble.org/api/about
JOOBLE_API_KEY=your_jooble_api_key
# Remotive: no key needed (free public API)

# ═══════════════════════════════════════════════════════════════════════════════
# Browser Worker
# ═══════════════════════════════════════════════════════════════════════════════

HEADLESS=true
SESSION_DIR=/data/sessions

# ═══════════════════════════════════════════════════════════════════════════════
# Security
# ═══════════════════════════════════════════════════════════════════════════════

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your_fernet_key_here

# ═══════════════════════════════════════════════════════════════════════════════
# PROXY Configuration (Two-tier)
# ═══════════════════════════════════════════════════════════════════════════════

PROXY_DATACENTER_URLS=
PROXY_RESIDENTIAL_URL=
PROXY_RESIDENTIAL_USER=
PROXY_RESIDENTIAL_PASS=
PROXY_ENABLED=false

# ═══════════════════════════════════════════════════════════════════════════════
# NEKO Cloud Browser
# ═══════════════════════════════════════════════════════════════════════════════

NEKO_IMAGE=jobblitz-neko:latest
NEKO_SESSION_TTL_MINUTES=10
LOGIN_HOST=host.docker.internal

# ═══════════════════════════════════════════════════════════════════════════════
# LOGIN METHOD — handoff (headed window) or cookie (import cookies JSON)
# ═══════════════════════════════════════════════════════════════════════════════

LOGIN_METHOD=cookie

# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL — defaults work for local dev
# ═══════════════════════════════════════════════════════════════════════════════

VERSION=1.0.0
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
UPLOAD_DIR=./uploads
SCREENSHOT_DIR=./screenshots
MAX_APPLICATIONS_PER_HOUR=20
MAX_APPLICATIONS_PER_DAY=100
MIN_MATCH_SCORE_TO_APPLY=0.3
MIN_MATCH_SCORE_TO_SAVE=0.2

# ═══════════════════════════════════════════════════════════════════════════════
# 3-PLANE ARCHITECTURE — Service URLs
# ═══════════════════════════════════════════════════════════════════════════════

ADK_ORCHESTRATOR_URL=http://adk-orchestrator:8001
BROWSER_WORKER_URL=http://browser-worker:8002
BACKEND_API_URL=http://backend:8000/api/v1
FRONTEND_URL=http://localhost:3001

# ═══════════════════════════════════════════════════════════════════════════════
# CORS — comma-separated list of allowed origins
# ═══════════════════════════════════════════════════════════════════════════════
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
