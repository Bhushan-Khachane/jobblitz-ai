# ──────────────────────────────────────────────────────────────────────────────
# JobBlitz AI — Environment Variables
# Copy this file to .env and fill in the values.
# ──────────────────────────────────────────────────────────────────────────────

# ═══════════════════════════════════════════════════════════════════════════════
# REQUIRED — App will not start without these
# ═══════════════════════════════════════════════════════════════════════════════

# PostgreSQL connection string (async driver)
DATABASE_URL=postgresql+asyncpg://jobblitz:jobblitz@postgres:5432/jobblitz

# JWT signing secret — minimum 32 characters, use: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# Fernet key for encrypting stored credentials — generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL — defaults work for local dev
# ═══════════════════════════════════════════════════════════════════════════════

# Redis URL (used by Celery and password reset tokens)
REDIS_URL=redis://redis:6379/0

# JWT algorithm and token lifetimes
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# OpenRouter AI (for resume tailoring / cover letter generation)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini

# File storage directories
UPLOAD_DIR=./uploads
SCREENSHOT_DIR=./screenshots

# Rate limits
MAX_APPLICATIONS_PER_HOUR=20
MAX_APPLICATIONS_PER_DAY=100

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
