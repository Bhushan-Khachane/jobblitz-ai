# ── Required ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://jobblitz:jobblitz@localhost:5432/jobblitz
REDIS_URL=redis://localhost:6379/0
BETTER_AUTH_SECRET=change-me-32-char-minimum-secret-key

# ── API & Web ─────────────────────────────────────────────────────────────────
API_URL=http://localhost:8000
WEB_URL=http://localhost:3000

# ── Object Storage (S3 / R2 / MinIO) ──────────────────────────────────────────
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_NAME=jobblitz

# ── LLM Providers ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
PERPLEXITY_API_KEY=

# ── Observability ─────────────────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# ── Browser Automation ──────────────────────────────────────────────────────
BROWSERBASE_API_KEY=
STAGEHAND_ENABLED=false

# ── Feature Flags ───────────────────────────────────────────────────────────────
ENABLE_LANGGRAPH=false
ENABLE_STAGEHAND=false
ENABLE_NEW_FRONTEND=false

# ── Internal Service Auth ───────────────────────────────────────────────────────
INTERNAL_API_KEY=jobblitz-internal-secret
INTERNAL_SERVICE_TOKEN=jobblitz-internal-secret

# ── Legacy (Python backend) ───────────────────────────────────────────────────
# These are used by the legacy FastAPI backend during migration
SECRET_KEY=change-me-32-char-minimum-secret-key
FERNET_KEY=change-me-32-char-fernet-key
GEMINI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OLLAMA_BASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
